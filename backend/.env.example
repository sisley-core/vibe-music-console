# Vibe Console Backend Configuration
# Copy this file to .env and fill in your values

# === LLM API ===
# DeepSeek, OpenAI, or any OpenAI-compatible API
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# === LG TV (optional) ===
# Find your TV's IP in TV Settings → Network
# Find MAC address in TV Settings → Network → Wi-Fi Connection → Advanced
LG_TV_IP=192.168.1.100
LG_TV_MAC=AA:BB:CC:DD:EE:FF
LG_HDMI_APPLETV=HDMI_1
LG_HDMI_MAC=HDMI_3

# === Storage ===
# Where to store music library metadata (JSON files)
MEMORY_DIR=~/vibe-console/memory
